---
import BaseLayout from './BaseLayout.astro';

type Props = {
  kind: string;
  title: string;
  summary: string;
  date: string;
  path: string;
  tags?: string[];
  status?: string;
};

const { kind, title, summary, date, path, tags = [], status } = Astro.props;
---

<BaseLayout title={title} description={summary} path={path}>
  <article class="content-page shell">
    <header>
      <div class="content-meta">
        <span class="kind-badge">{kind}</span>
        <span class="date">{date}</span>
        {status && <span class="status-badge" data-status={status}>{status}</span>}
      </div>
      <h1>{title}</h1>
      <p class="lead">{summary}</p>
      {tags.length > 0 && (
        <ul class="tag-list">
          {tags.map((tag) => <li class="tag">{tag}</li>)}
        </ul>
      )}
    </header>
    <div class="prose">
      <slot />
    </div>
    <nav class="back no-print" aria-label="返回列表">
      <a href={kind === 'PROJECT' ? '/projects' : kind === 'ARTICLE' ? '/blog' : '/notes'}>
        ← 返回{kind === 'PROJECT' ? '项目' : kind === 'ARTICLE' ? '文章' : '笔记'}列表
      </a>
    </nav>
  </article>
</BaseLayout>

<style>
  .content-page {
    padding-bottom: 80px;
  }

  header {
    max-width: 720px;
    padding-block: clamp(48px, 8vw, 88px);
    margin-bottom: 48px;
    border-bottom: 1px solid var(--border);
  }

  .content-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }

  .kind-badge {
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--blue);
    letter-spacing: 0.05em;
  }

  .date {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-tertiary);
  }

  .status-badge {
    font-family: var(--mono);
    font-size: 0.62rem;
    font-weight: 600;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 999px;
    letter-spacing: 0.05em;
  }

  .status-badge[data-status="active"] {
    color: var(--green);
    background: var(--green-light);
  }

  .status-badge[data-status="completed"] {
    color: var(--blue);
    background: var(--blue-light);
  }

  .status-badge[data-status="experimental"] {
    color: var(--purple);
    background: var(--purple-light);
  }

  .status-badge[data-status="seedling"] {
    color: var(--green);
    background: var(--green-light);
  }

  .status-badge[data-status="growing"] {
    color: var(--amber);
    background: var(--amber-light);
  }

  .status-badge[data-status="evergreen"] {
    color: var(--blue);
    background: var(--blue-light);
  }

  h1 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .lead {
    max-width: 640px;
    margin: 16px 0 20px;
    color: var(--text-secondary);
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .back {
    width: min(100%, var(--reading));
    margin: 56px auto 0;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }

  .back a {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 200ms ease;
  }

  .back a:hover {
    color: var(--blue);
  }
</style>
