---
import BaseLayout from './BaseLayout.astro';

type Props = {
  kind: string;
  title: string;
  summary: string;
  date: string;
  path: string;
  tags?: string[];
  status?: string;
};

const { kind, title, summary, date, path, tags = [], status } = Astro.props;

const kindLabel =
  kind === 'PROJECT' ? '项目' :
  kind === 'ARTICLE' ? '文章' : '笔记';

const backHref =
  kind === 'PROJECT' ? '/projects' :
  kind === 'ARTICLE' ? '/blog' : '/notes';
---

<BaseLayout title={title} description={summary} path={path}>
  <article class="content-page shell">
    <header class="content-hero fade-in">
      <div class="content-meta">
        <span class="kind-badge">{kind}</span>
        <span class="date">{date}</span>
        {status && <span class="status-badge" data-status={status}>{status}</span>}
      </div>
      <h1>{title}</h1>
      <p class="lead">{summary}</p>
      {tags.length > 0 && (
        <ul class="tag-list">
          {tags.map((tag) => <li class="tag">{tag}</li>)}
        </ul>
      )}
    </header>
    <div class="prose fade-in fade-in-delay-1">
      <slot />
    </div>
    <nav class="back no-print fade-in fade-in-delay-2" aria-label="返回列表">
      <a href={backHref}>← 返回{kindLabel}列表</a>
    </nav>
  </article>
</BaseLayout>

<style>
  .content-page {
    padding-bottom: 80px;
  }

  .content-hero {
    max-width: 720px;
    padding-block: clamp(56px, 9vw, 96px);
    margin-bottom: 56px;
    border-bottom: 1px solid var(--border);
  }

  .content-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
  }

  .kind-badge {
    font-family: var(--mono);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    padding: 3px 10px;
    border-radius: 4px;
    color: var(--blue);
    background: var(--blue-light);
  }

  .date {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-tertiary);
    letter-spacing: 0.03em;
  }

  .status-badge {
    font-family: var(--mono);
    font-size: 0.62rem;
    font-weight: 600;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 999px;
    letter-spacing: 0.06em;
  }

  .status-badge[data-status="active"] {
    color: var(--green);
    background: var(--green-light);
  }

  .status-badge[data-status="completed"] {
    color: var(--blue);
    background: var(--blue-light);
  }

  .status-badge[data-status="experimental"] {
    color: var(--purple);
    background: var(--purple-light);
  }

  .status-badge[data-status="seedling"] {
    color: var(--amber);
    background: var(--amber-light);
  }

  .status-badge[data-status="growing"] {
    color: var(--amber);
    background: var(--amber-light);
  }

  .status-badge[data-status="evergreen"] {
    color: var(--green);
    background: var(--green-light);
  }

  h1 {
    margin: 0;
    font-family: Georgia, 'Songti SC', serif;
    font-size: clamp(2.2rem, 5.5vw, 3.6rem);
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  .lead {
    max-width: 640px;
    margin: 18px 0 22px;
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.78;
    letter-spacing: 0.005em;
  }

  .back {
    width: min(100%, var(--reading));
    margin: 64px auto 0;
    padding-top: 22px;
    border-top: 1px solid var(--border);
  }

  .back a {
    font-family: var(--mono);
    font-size: 0.76rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: all 200ms ease;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .back a:hover {
    color: var(--blue);
    transform: translateX(-3px);
  }
</style>
