---
type Props = {
  index: number;
  kind: 'Project' | 'Article' | 'Note';
  title: string;
  summary: string;
  href: string;
  date: string;
  meta?: string;
  tags?: string[];
};

const { index, kind, title, summary, href, date, meta, tags = [] } = Astro.props;
---

<article class="entry-card">
  <a href={href} aria-label={`阅读 ${title}`}>
    <div class="card-header">
      <div class="card-meta-left">
        <span class="kind">{kind}</span>
        <span class="index" aria-hidden="true">{String(index).padStart(2, '0')}</span>
      </div>
      <span class="date">{date}</span>
    </div>
    <h3>{title}</h3>
    <p class="summary">{summary}</p>
    <div class="card-footer">
      {tags.length > 0 && (
        <ul class="tag-list" aria-label="标签">
          {tags.slice(0, 4).map((tag) => <li class="tag">{tag}</li>)}
        </ul>
      )}
      {meta && <span class="meta">{meta}</span>}
    </div>
    <span class="arrow" aria-hidden="true">→</span>
  </a>
</article>

<style>
  .entry-card {
    border-bottom: 1px solid var(--border);
    transition: all 250ms ease;
  }

  .entry-card:last-child {
    border-bottom: none;
  }

  .entry-card:hover {
    background: rgba(255, 255, 255, 0.6);
  }

  .entry-card > a {
    display: block;
    padding: 28px 32px;
    text-decoration: none;
    color: inherit;
    position: relative;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .card-meta-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .kind {
    font-family: var(--mono);
    font-size: 0.64rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--blue);
    letter-spacing: 0.08em;
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--blue-light);
  }

  .index {
    font-family: var(--mono);
    font-size: 0.62rem;
    color: var(--text-tertiary);
    letter-spacing: 0.04em;
  }

  .date {
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--text-tertiary);
  }

  h3 {
    margin: 0;
    font-family: Georgia, 'Songti SC', serif;
    font-size: 1.4rem;
    font-weight: 400;
    line-height: 1.35;
    letter-spacing: -0.015em;
    transition: color 200ms ease;
  }

  .entry-card:hover h3 {
    color: var(--blue);
  }

  .summary {
    max-width: 680px;
    margin: 9px 0 16px;
    color: var(--text-secondary);
    font-size: 0.94rem;
    line-height: 1.72;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .meta {
    font-family: var(--mono);
    font-size: 0.66rem;
    font-weight: 500;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    padding: 2px 8px;
    border-radius: 999px;
    border: 1px solid var(--border);
  }

  .arrow {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-tertiary);
    font-size: 1.2rem;
    font-family: Georgia, serif;
    opacity: 0;
    transition: all 250ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .entry-card:hover .arrow {
    opacity: 1;
    transform: translateY(-50%) translateX(6px);
    color: var(--blue);
  }

  @media (max-width: 680px) {
    .entry-card > a {
      padding: 22px 18px;
    }

    .arrow {
      display: none;
    }

    h3 {
      font-size: 1.2rem;
    }
  }
</style>
