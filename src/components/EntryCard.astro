---
type Props = {
  index: number;
  kind: 'Project' | 'Article' | 'Note';
  title: string;
  summary: string;
  href: string;
  date: string;
  meta?: string;
  tags?: string[];
};

const { index, kind, title, summary, href, date, meta, tags = [] } = Astro.props;
---

<article class="entry-card">
  <a href={href} aria-label={`阅读 ${title}`}>
    <div class="card-header">
      <span class="kind">{kind}</span>
      <span class="date">{date}</span>
    </div>
    <h3>{title}</h3>
    <p class="summary">{summary}</p>
    <div class="card-footer">
      {tags.length > 0 && (
        <ul class="tag-list" aria-label="标签">
          {tags.slice(0, 4).map((tag) => <li class="tag">{tag}</li>)}
        </ul>
      )}
      {meta && <span class="meta">{meta}</span>}
    </div>
    <span class="arrow" aria-hidden="true">→</span>
  </a>
</article>

<style>
  .entry-card {
    border-bottom: 1px solid var(--border);
    transition: background-color 200ms ease;
  }

  .entry-card:hover {
    background: rgba(255, 255, 255, 0.65);
  }

  .entry-card > a {
    display: block;
    padding: 26px 28px;
    text-decoration: none;
    color: inherit;
    position: relative;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .kind {
    font-family: var(--mono);
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--blue);
    letter-spacing: 0.05em;
  }

  .date {
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--text-tertiary);
  }

  h3 {
    margin: 0;
    font-family: Georgia, 'Songti SC', serif;
    font-size: 1.35rem;
    font-weight: 400;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }

  .summary {
    max-width: 680px;
    margin: 8px 0 14px;
    color: var(--text-secondary);
    font-size: 0.92rem;
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .meta {
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .arrow {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-tertiary);
    font-size: 1.1rem;
    opacity: 0;
    transition: all 200ms ease;
  }

  .entry-card:hover .arrow {
    opacity: 1;
    transform: translateY(-50%) translateX(4px);
    color: var(--blue);
  }

  @media (max-width: 680px) {
    .entry-card > a {
      padding: 22px 18px;
    }

    .arrow {
      display: none;
    }
  }
</style>
