---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryCard from '../../components/EntryCard.astro';
import { byNewest, formatDate, visible } from '../../utils/content';

const notes = visible(await getCollection('notes')).sort(byNewest);
---

<BaseLayout title="Notes" description="持续更新的学习笔记。" path="/notes">
  <section class="shell page-hero">
    <p class="eyebrow fade-in">Notes</p>
    <h1 class="fade-in fade-in-delay-1">学习笔记</h1>
    <p class="hero-desc fade-in fade-in-delay-2">
      Notes 是更轻的知识记录，允许阶段性、不完整和持续修订。它们不追求文章式完整结论。
    </p>
  </section>

  <section class="section shell">
    {
      notes.length > 0 ? (
        <div class="content-list fade-in fade-in-delay-2">
          {notes.map((note, index) => (
            <EntryCard
              index={index + 1}
              kind="Note"
              title={note.data.title}
              summary={note.data.summary}
              href={`/notes/${note.id}`}
              date={formatDate(note.data.updatedAt)}
              meta={note.data.status === 'evergreen' ? 'Evergreen' : note.data.topic}
              tags={note.data.tags}
            />
          ))}
        </div>
      ) : (
        <div class="content-list">
          <p class="empty-state">还没有笔记，敬请期待。</p>
        </div>
      )
    }
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding-block: clamp(64px, 9vw, 112px) 44px;
    border-bottom: 1px solid var(--border);
  }

  .page-hero h1 {
    max-width: 800px;
    margin: 0;
    font-family: Georgia, 'Songti SC', serif;
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 400;
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .hero-desc {
    max-width: 480px;
    margin: 20px 0 0;
    color: var(--text-secondary);
    font-size: 1.02rem;
    line-height: 1.8;
  }
</style>
