---
import BaseLayout from '../layouts/BaseLayout.astro';
import { desktopApps, desktopSettings } from '../data/desktop';
import { profile } from '../data/profile';
---

<BaseLayout
  title="Desktop"
  description="项目、文章、笔记与有趣实验的数字桌面。"
  path="/"
  immersive
  themeColor="#0a1727"
>
  <div
    class="computer"
    data-computer
    data-state="off"
    style={`--desktop-wallpaper: url("${desktopSettings.wallpaper}")`}
  >
    <script is:inline>
      if (sessionStorage.getItem('personal-desktop-powered-on') === 'true') {
        document.currentScript.parentElement.dataset.state = 'desktop';
        document.currentScript.parentElement.dataset.restored = 'true';
      }
    </script>
    <section class="boot-screen" data-boot-screen aria-label="开机界面">
      <div class="power-panel">
        <button class="power-button" type="button" data-power-button aria-label="启动个人网站">
          <span class="power-symbol" aria-hidden="true"></span>
        </button>
        <p class="power-title">POWER ON</p>
        <p class="power-hint">点击启动我的个人空间</p>
      </div>

      <div class="boot-sequence" aria-live="polite">
        <div class="boot-mark" aria-hidden="true">
          <i></i><i></i><i></i><i></i>
        </div>
        <p class="boot-name">Personal Desktop</p>
        <div class="boot-progress" aria-hidden="true"><span></span></div>
        <p class="boot-status" data-boot-status>正在唤醒桌面...</p>
      </div>
    </section>

    <section class="desktop" data-desktop aria-label="个人网站桌面" aria-hidden="true" inert>
      <header class="menu-bar">
        <div class="menu-left">
          <a class="menu-brand" href="/" aria-label="桌面首页">
            <i></i><i></i><i></i><i></i>
          </a>
          <strong>Desktop</strong>
          <a href="/about">关于我</a>
          <a href="/projects">项目</a>
          <a href="/blog">博客</a>
          <a href="/notes">笔记</a>
        </div>
        <div class="menu-right">
          <span class="menu-status" aria-label="在线状态"><i></i> Available</span>
          <time data-menu-time>Tue 09:41</time>
        </div>
      </header>

      <div class="desktop-space">
        <aside class="system-widget" aria-label="网站状态">
          <header class="system-widget-header">
            <span><i></i> SYSTEM ONLINE</span>
            <span>HANGZHOU</span>
          </header>

          <div class="weather-panel">
            <div class="weather-icon" data-weather-icon aria-hidden="true">◌</div>
            <div>
              <p class="weather-temperature"><span data-weather-temperature>--</span>°</p>
              <p class="weather-description" data-weather-description>正在获取天气</p>
            </div>
          </div>

          <div class="system-stats">
            <div class="system-stat">
              <span>本站运行</span>
              <strong data-site-uptime>0 天 00 时</strong>
            </div>
            <div class="system-stat">
              <span>本机访问</span>
              <strong><span data-visit-count>1</span> 次</strong>
            </div>
          </div>

          <p class="system-note">Weather via Open-Meteo · Since 2026.06.09</p>
        </aside>

        <nav class="shortcut-grid" aria-label="桌面快捷方式">
          {desktopApps.map((app, index) => (
            <a
              class="desktop-shortcut"
              href={app.href}
              style={`--shortcut-order: ${index}`}
              aria-label={`${app.label}：${app.description}`}
            >
              <img src={app.icon} alt="" width="112" height="112" draggable="false" />
              <span>{app.label}</span>
            </a>
          ))}
        </nav>
      </div>

      <nav class="dock" aria-label="常用操作">
        <a class="dock-item active" href="/" aria-label="桌面" data-tooltip="Desktop">
          <svg viewBox="0 0 32 32" aria-hidden="true">
            <rect x="4" y="6" width="24" height="18" rx="3"></rect>
            <path d="M11 28h10M16 24v4"></path>
          </svg>
        </a>
        <a
          class="dock-item"
          href={`https://github.com/${profile.handle}`}
          target="_blank"
          rel="noreferrer"
          aria-label="GitHub"
          data-tooltip="GitHub"
        >
          <svg viewBox="0 0 32 32" aria-hidden="true">
            <path d="M16 4a12 12 0 0 0-3.8 23.4c.6.1.8-.2.8-.6v-2.3c-3.4.7-4.1-1.4-4.1-1.4-.5-1.4-1.4-1.8-1.4-1.8-1.1-.8.1-.8.1-.8 1.3.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.4 3.6 1 .1-.8.4-1.4.8-1.7-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.3-3.2-.1-.3-.6-1.6.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.2 2.9.1 3.2.8.8 1.3 1.9 1.3 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6A12 12 0 0 0 16 4Z"></path>
          </svg>
        </a>
        <a class="dock-item" href="/resume" aria-label="简历" data-tooltip="Resume">
          <svg viewBox="0 0 32 32" aria-hidden="true">
            <path d="M8 4h11l5 5v19H8z"></path>
            <path d="M19 4v5h5M12 15h8M12 20h8M12 24h5"></path>
          </svg>
        </a>
        <a
          class="dock-item"
          href={`mailto:${profile.email}`}
          aria-label="发送邮件"
          data-tooltip="Mail"
        >
          <svg viewBox="0 0 32 32" aria-hidden="true">
            <rect x="4" y="7" width="24" height="18" rx="3"></rect>
            <path d="m6 10 10 8 10-8"></path>
          </svg>
        </a>
        <span class="dock-divider" aria-hidden="true"></span>
        <button
          class="dock-item shutdown"
          type="button"
          data-shutdown-button
          aria-label="关机"
          data-tooltip="Shut Down"
        >
          <svg viewBox="0 0 32 32" aria-hidden="true">
            <path d="M16 4v11"></path>
            <path d="M10 8.5a10 10 0 1 0 12 0"></path>
          </svg>
        </button>
      </nav>
    </section>
  </div>
</BaseLayout>

<script>
  const computer = document.querySelector<HTMLElement>('[data-computer]');
  const powerButton = document.querySelector<HTMLButtonElement>('[data-power-button]');
  const shutdownButton = document.querySelector<HTMLButtonElement>('[data-shutdown-button]');
  const desktop = document.querySelector<HTMLElement>('[data-desktop]');
  const bootScreen = document.querySelector<HTMLElement>('[data-boot-screen]');
  const bootStatus = document.querySelector<HTMLElement>('[data-boot-status]');
  const menuTime = document.querySelector<HTMLTimeElement>('[data-menu-time]');
  const weatherIcon = document.querySelector<HTMLElement>('[data-weather-icon]');
  const weatherTemperature = document.querySelector<HTMLElement>('[data-weather-temperature]');
  const weatherDescription = document.querySelector<HTMLElement>('[data-weather-description]');
  const siteUptime = document.querySelector<HTMLElement>('[data-site-uptime]');
  const visitCount = document.querySelector<HTMLElement>('[data-visit-count]');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const siteLaunchedAt = new Date('2026-06-09T00:00:00+08:00').getTime();
  const powerStateKey = 'personal-desktop-powered-on';

  const weatherCodes: Record<number, { icon: string; label: string }> = {
    0: { icon: '☀', label: '晴朗' },
    1: { icon: '◒', label: '大致晴朗' },
    2: { icon: '◒', label: '局部多云' },
    3: { icon: '☁', label: '阴天' },
    45: { icon: '≋', label: '有雾' },
    48: { icon: '≋', label: '雾凇' },
    51: { icon: '⋰', label: '小毛毛雨' },
    53: { icon: '⋰', label: '毛毛雨' },
    55: { icon: '⋰', label: '强毛毛雨' },
    61: { icon: '☂', label: '小雨' },
    63: { icon: '☂', label: '中雨' },
    65: { icon: '☂', label: '大雨' },
    71: { icon: '✣', label: '小雪' },
    73: { icon: '✣', label: '中雪' },
    75: { icon: '✣', label: '大雪' },
    80: { icon: '☂', label: '阵雨' },
    81: { icon: '☂', label: '中阵雨' },
    82: { icon: '☂', label: '强阵雨' },
    95: { icon: 'ϟ', label: '雷雨' },
    96: { icon: 'ϟ', label: '雷雨伴冰雹' },
    99: { icon: 'ϟ', label: '强雷雨伴冰雹' },
  };

  const updateClock = () => {
    if (!menuTime) return;

    const now = new Date();
    menuTime.dateTime = now.toISOString();
    menuTime.textContent = new Intl.DateTimeFormat('zh-CN', {
      weekday: 'short',
      hour: '2-digit',
      minute: '2-digit',
      hour12: false,
    }).format(now);
  };

  const updateSiteStats = () => {
    if (siteUptime) {
      const elapsed = Math.max(0, Date.now() - siteLaunchedAt);
      const days = Math.floor(elapsed / 86_400_000);
      const hours = Math.floor((elapsed % 86_400_000) / 3_600_000);
      siteUptime.textContent = `${days} 天 ${String(hours).padStart(2, '0')} 时`;
    }

    if (visitCount) {
      const storageKey = 'personal-desktop-local-visits';
      const sessionKey = 'personal-desktop-visit-counted';
      let visits = Number.parseInt(localStorage.getItem(storageKey) || '0', 10);

      if (!sessionStorage.getItem(sessionKey)) {
        visits += 1;
        localStorage.setItem(storageKey, String(visits));
        sessionStorage.setItem(sessionKey, 'true');
      }

      visitCount.textContent = String(Math.max(1, visits));
    }
  };

  const updateWeather = async () => {
    if (!weatherTemperature || !weatherDescription || !weatherIcon) return;

    try {
      const response = await fetch(
        'https://api.open-meteo.com/v1/forecast?latitude=30.2741&longitude=120.1551&current=temperature_2m,weather_code&timezone=Asia%2FShanghai',
      );
      if (!response.ok) throw new Error('Weather request failed');

      const data = await response.json();
      const temperature = Math.round(data.current.temperature_2m);
      const weather = weatherCodes[data.current.weather_code] || { icon: '◌', label: '天气更新中' };

      weatherTemperature.textContent = String(temperature);
      weatherDescription.textContent = weather.label;
      weatherIcon.textContent = weather.icon;
    } catch {
      weatherTemperature.textContent = '--';
      weatherDescription.textContent = '天气暂不可用';
      weatherIcon.textContent = '◌';
    }
  };

  const revealDesktop = (focusDesktop = true) => {
    if (!computer || !desktop || !bootScreen) return;

    computer.dataset.state = 'desktop';
    desktop.removeAttribute('inert');
    desktop.setAttribute('aria-hidden', 'false');
    bootScreen.setAttribute('aria-hidden', 'true');
    if (focusDesktop) {
      window.setTimeout(() => desktop.querySelector<HTMLElement>('a')?.focus(), reducedMotion ? 0 : 650);
    }
  };

  powerButton?.addEventListener('click', () => {
    if (!computer || computer.dataset.state !== 'off') return;

    computer.dataset.state = 'booting';
    sessionStorage.setItem(powerStateKey, 'true');
    if (bootStatus) bootStatus.textContent = '正在载入作品与想法...';
    window.setTimeout(revealDesktop, reducedMotion ? 180 : 1800);
  });

  shutdownButton?.addEventListener('click', () => {
    if (!computer || !desktop || !bootScreen) return;

    computer.dataset.state = 'shutting-down';
    sessionStorage.removeItem(powerStateKey);
    desktop.setAttribute('inert', '');
    desktop.setAttribute('aria-hidden', 'true');
    bootScreen.setAttribute('aria-hidden', 'false');

    window.setTimeout(() => {
      computer.dataset.state = 'off';
      if (bootStatus) bootStatus.textContent = '正在唤醒桌面...';
      powerButton?.focus();
    }, reducedMotion ? 100 : 700);
  });

  updateClock();
  updateSiteStats();
  updateWeather();
  if (sessionStorage.getItem(powerStateKey) === 'true') revealDesktop(false);
  window.setInterval(updateClock, 30_000);
  window.setInterval(updateSiteStats, 3_600_000);
  window.setInterval(updateWeather, 30 * 60_000);
</script>

<style>
  :global(html) {
    background: #060b12;
  }

  :global(body.immersive) {
    overflow: hidden;
    background: #060b12;
  }

  :global(.immersive-main) {
    min-height: 100dvh;
  }

  .computer {
    position: relative;
    min-height: 100dvh;
    overflow: hidden;
    background: #060b12;
    color: #fff;
    isolation: isolate;
  }

  .boot-screen,
  .desktop {
    position: absolute;
    inset: 0;
  }

  .boot-screen {
    z-index: 10;
    display: grid;
    place-items: center;
    background:
      radial-gradient(circle at 50% 45%, rgba(41, 58, 76, 0.24), transparent 30%),
      #06090e;
    transition: opacity 700ms ease, visibility 700ms;
  }

  .power-panel,
  .boot-sequence {
    position: absolute;
    display: grid;
    justify-items: center;
  }

  .power-panel {
    transition: opacity 260ms ease, transform 260ms ease;
  }

  .power-button {
    position: relative;
    display: grid;
    width: 118px;
    height: 118px;
    padding: 0;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 50%;
    color: #e9f5ff;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.015)),
      #0a1018;
    box-shadow:
      0 24px 70px rgba(0, 0, 0, 0.55),
      inset 0 1px 1px rgba(255, 255, 255, 0.14);
    cursor: pointer;
    transition: transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease;
  }

  .power-button::before {
    position: absolute;
    inset: -10px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: inherit;
    content: '';
    transition: inset 220ms ease, opacity 220ms ease;
  }

  .power-button:hover {
    border-color: rgba(146, 211, 255, 0.6);
    box-shadow:
      0 0 0 10px rgba(90, 183, 245, 0.04),
      0 0 55px rgba(73, 177, 244, 0.18),
      inset 0 1px 1px rgba(255, 255, 255, 0.18);
    transform: scale(1.04);
  }

  .power-button:hover::before {
    inset: -16px;
    opacity: 0;
  }

  .power-button:active {
    transform: scale(0.97);
  }

  .power-button:focus-visible,
  .desktop a:focus-visible,
  .dock-item:focus-visible {
    outline: 3px solid rgba(151, 219, 255, 0.9);
    outline-offset: 4px;
  }

  .power-symbol {
    position: relative;
    width: 42px;
    height: 42px;
    border: 4px solid currentColor;
    border-top-color: transparent;
    border-radius: 50%;
  }

  .power-symbol::before {
    position: absolute;
    top: -11px;
    left: 50%;
    width: 4px;
    height: 23px;
    border-radius: 10px;
    background: currentColor;
    content: '';
    transform: translateX(-50%);
  }

  .power-title {
    margin: 28px 0 0;
    color: rgba(255, 255, 255, 0.9);
    font-family: var(--mono);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.22em;
  }

  .power-hint {
    margin: 9px 0 0;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.76rem;
    letter-spacing: 0.04em;
  }

  .boot-sequence {
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: opacity 300ms ease 180ms, transform 300ms ease 180ms;
  }

  .boot-mark {
    display: grid;
    width: 66px;
    height: 66px;
    grid-template-columns: repeat(2, 10px);
    grid-template-rows: repeat(2, 10px);
    gap: 4px;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 19px;
    background: rgba(255, 255, 255, 0.08);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.12);
  }

  .boot-mark i,
  .menu-brand i {
    width: 100%;
    height: 100%;
    border-radius: 2px;
    background: currentColor;
  }

  .boot-name {
    margin: 20px 0 24px;
    color: rgba(255, 255, 255, 0.84);
    font-size: 0.83rem;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .boot-progress {
    width: min(240px, 62vw);
    height: 4px;
    overflow: hidden;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.11);
  }

  .boot-progress span {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: inherit;
    background: #f4f7fa;
    transform: translateX(-100%);
  }

  .boot-status {
    margin: 13px 0 0;
    color: rgba(255, 255, 255, 0.34);
    font-size: 0.7rem;
  }

  [data-state='booting'] .power-panel {
    opacity: 0;
    pointer-events: none;
    transform: scale(0.9);
  }

  [data-state='booting'] .boot-sequence {
    opacity: 1;
    transform: none;
  }

  [data-state='booting'] .boot-progress span {
    animation: boot-progress 1.65s cubic-bezier(0.25, 0.8, 0.25, 1) forwards;
  }

  [data-state='desktop'] .boot-screen {
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
  }

  [data-state='shutting-down'] .boot-screen {
    background: #020407;
  }

  [data-state='shutting-down'] .power-panel,
  [data-state='shutting-down'] .boot-sequence {
    opacity: 0;
  }

  .desktop {
    display: grid;
    grid-template-rows: 38px minmax(0, 1fr);
    background-image:
      linear-gradient(180deg, rgba(3, 12, 23, 0.02), rgba(3, 10, 20, 0.12)),
      var(--desktop-wallpaper);
    background-position: center;
    background-size: cover;
    opacity: 0;
    pointer-events: none;
    transform: scale(1.035);
    transition: opacity 850ms ease, transform 1100ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-state='desktop'] .desktop {
    opacity: 1;
    pointer-events: auto;
    transform: none;
  }

  [data-restored='true'] .desktop {
    transition: none;
  }

  [data-state='shutting-down'] .desktop {
    opacity: 0;
    transform: scale(0.985);
    transition-duration: 500ms;
  }

  .menu-bar {
    position: relative;
    z-index: 5;
    display: flex;
    min-width: 0;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 0 18px;
    color: rgba(255, 255, 255, 0.92);
    background: rgba(5, 16, 28, 0.52);
    border-bottom: 1px solid rgba(255, 255, 255, 0.09);
    box-shadow: 0 2px 20px rgba(5, 10, 18, 0.08);
    backdrop-filter: blur(22px) saturate(1.4);
    -webkit-backdrop-filter: blur(22px) saturate(1.4);
    font-size: 0.68rem;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.24);
  }

  .menu-left,
  .menu-right {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 16px;
  }

  .menu-brand {
    display: grid;
    width: 24px;
    height: 24px;
    grid-template-columns: repeat(2, 4px);
    grid-template-rows: repeat(2, 4px);
    gap: 2px;
    place-items: center;
    border-radius: 8px;
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
    text-decoration: none;
  }

  .menu-left a:not(.menu-brand) {
    color: inherit;
    text-decoration: none;
  }

  .menu-left a:hover {
    color: #fff;
    opacity: 0.7;
  }

  .menu-status {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .menu-status i {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #65e6a5;
    box-shadow: 0 0 9px rgba(101, 230, 165, 0.75);
  }

  .menu-right time {
    white-space: nowrap;
  }

  .desktop-space {
    position: relative;
    display: grid;
    grid-template-columns: minmax(270px, 320px) minmax(80px, 1fr) auto;
    min-height: 0;
    align-items: start;
    gap: clamp(32px, 5vw, 88px);
    padding: clamp(30px, 4vw, 54px) clamp(26px, 4vw, 58px) 104px;
  }

  .system-widget {
    width: 100%;
    padding: 17px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 20px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.035)),
      rgba(7, 27, 43, 0.2);
    box-shadow:
      0 22px 60px rgba(3, 13, 24, 0.16),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(20px) saturate(1.18);
    -webkit-backdrop-filter: blur(20px) saturate(1.18);
    text-shadow: 0 2px 16px rgba(3, 12, 23, 0.34);
  }

  .system-widget-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    color: rgba(255, 255, 255, 0.58);
    font-family: var(--mono);
    font-size: 0.54rem;
    letter-spacing: 0.09em;
  }

  .system-widget-header span:first-child {
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .system-widget-header i {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #65e6a5;
    box-shadow: 0 0 9px rgba(101, 230, 165, 0.7);
  }

  .weather-panel {
    display: flex;
    min-height: 86px;
    align-items: center;
    gap: 14px;
  }

  .weather-icon {
    display: grid;
    width: 54px;
    height: 54px;
    place-items: center;
    color: #ffd39b;
    font-family: Georgia, serif;
    font-size: 2.75rem;
    line-height: 1;
    filter: drop-shadow(0 0 18px rgba(255, 201, 135, 0.18));
  }

  .weather-temperature {
    margin: 0;
    font-family: Georgia, serif;
    font-size: 2.65rem;
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.06em;
  }

  .weather-description {
    margin: 6px 0 0;
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.76rem;
  }

  .system-stats {
    display: grid;
