---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Playground" description="来玩个小游戏放松一下。" path="/playground">
  <section class="shell page-header">
    <div>
      <p class="eyebrow">Playground</p>
      <h1>玩一下</h1>
    </div>
    <p>写代码累了？来玩个小游戏放松一下。用方向键或 WASD 控制蛇的方向。</p>
  </section>

  <section class="section shell">
    <div class="game-container">
      <div class="game-header">
        <div class="game-stats">
          <div class="stat">
            <span class="stat-label">分数</span>
            <span class="stat-value" id="score">0</span>
          </div>
          <div class="stat">
            <span class="stat-label">最高分</span>
            <span class="stat-value" id="high-score">0</span>
          </div>
        </div>
        <div class="game-controls">
          <button class="button-link secondary" id="start-btn">开始游戏</button>
        </div>
      </div>
      <canvas id="game-canvas" width="480" height="480"></canvas>
      <div class="game-info">
        <p>🎮 方向键 / WASD 控制方向 · 空格键暂停</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const canvas = document.getElementById('game-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const scoreEl = document.getElementById('score')!;
  const highScoreEl = document.getElementById('high-score')!;
  const startBtn = document.getElementById('start-btn')!;

  const GRID = 20;
  const COLS = canvas.width / GRID;
  const ROWS = canvas.height / GRID;

  type Point = { x: number; y: number };

  let snake: Point[] = [];
  let food: Point = { x: 0, y: 0 };
  let direction: Point = { x: 1, y: 0 };
  let nextDirection: Point = { x: 1, y: 0 };
  let score = 0;
  let highScore = parseInt(localStorage.getItem('snake-high-score') || '0');
  let gameLoop: number | null = null;
  let isRunning = false;
  let isPaused = false;

  highScoreEl.textContent = String(highScore);

  function init() {
    snake = [
      { x: 5, y: 10 },
      { x: 4, y: 10 },
      { x: 3, y: 10 },
    ];
    direction = { x: 1, y: 0 };
    nextDirection = { x: 1, y: 0 };
    score = 0;
    scoreEl.textContent = '0';
    isPaused = false;
    placeFood();
  }

  function placeFood() {
    do {
      food = {
        x: Math.floor(Math.random() * COLS),
        y: Math.floor(Math.random() * ROWS),
      };
    } while (snake.some((s) => s.x === food.x && s.y === food.y));
  }

  function update() {
    if (isPaused) return;

    direction = { ...nextDirection };
    const head = { x: snake[0].x + direction.x, y: snake[0].y + direction.y };

    // wall collision
    if (head.x < 0 || head.x >= COLS || head.y < 0 || head.y >= ROWS) {
      gameOver();
      return;
    }

    // self collision
    if (snake.some((s) => s.x === head.x && s.y === head.y)) {
      gameOver();
      return;
    }

    snake.unshift(head);

    // eat food
    if (head.x === food.x && head.y === food.y) {
      score++;
      scoreEl.textContent = String(score);
      placeFood();
    } else {
      snake.pop();
    }
  }

  function draw() {
    // background
    ctx.fillStyle = '#f9fafb';
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    // grid
    ctx.strokeStyle = '#f3f4f6';
    ctx.lineWidth = 0.5;
    for (let i = 0; i <= COLS; i++) {
      ctx.beginPath();
      ctx.moveTo(i * GRID, 0);
      ctx.lineTo(i * GRID, canvas.height);
      ctx.stroke();
    }
    for (let i = 0; i <= ROWS; i++) {
      ctx.beginPath();
      ctx.moveTo(0, i * GRID);
      ctx.lineTo(canvas.width, i * GRID);
      ctx.stroke();
    }

    // food
    ctx.fillStyle = '#ef4444';
    ctx.beginPath();
    ctx.arc(
      food.x * GRID + GRID / 2,
      food.y * GRID + GRID / 2,
      GRID / 2 - 2,
      0,
      Math.PI * 2,
    );
    ctx.fill();

    // snake
    snake.forEach((segment, i) => {
      const isHead = i === 0;
      ctx.fillStyle = isHead ? '#2563eb' : '#3b82f6';
      ctx.beginPath();
      ctx.roundRect(
        segment.x * GRID + 1,
        segment.y * GRID + 1,
        GRID - 2,
        GRID - 2,
        isHead ? 5 : 3,
      );
      ctx.fill();
    });

    // pause overlay
    if (isPaused) {
      ctx.fillStyle = 'rgba(17, 24, 39, 0.5)';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = '#fff';
      ctx.font = '600 24px "IBM Plex Mono", monospace';
      ctx.textAlign = 'center';
      ctx.fillText('已暂停', canvas.width / 2, canvas.height / 2);
    }
  }

  function gameOver() {
    if (gameLoop) {
      clearInterval(gameLoop);
      gameLoop = null;
    }
    isRunning = false;
    startBtn.textContent = '再来一局';

    if (score > highScore) {
      highScore = score;
      localStorage.setItem('snake-high-score', String(highScore));
      highScoreEl.textContent = String(highScore);
    }

    // death animation
    ctx.fillStyle = 'rgba(239, 68, 68, 0.15)';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = '#ef4444';
    ctx.font = '600 28px "IBM Plex Mono", monospace';
    ctx.textAlign = 'center';
    ctx.fillText(`游戏结束 · ${score} 分`, canvas.width / 2, canvas.height / 2);
  }

  function start() {
    if (isRunning) return;
    isRunning = true;
    startBtn.textContent = '游戏中...';
    init();
    draw();
    gameLoop = window.setInterval(() => {
      update();
      draw();
    }, 120);
  }

  startBtn.addEventListener('click', start);

  document.addEventListener('keydown', (e) => {
    if (!isRunning) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        start();
      }
      return;
    }

    switch (e.key) {
      case 'ArrowUp':
      case 'w':
      case 'W':
        if (direction.y !== 1) nextDirection = { x: 0, y: -1 };
        e.preventDefault();
        break;
      case 'ArrowDown':
      case 's':
      case 'S':
        if (direction.y !== -1) nextDirection = { x: 0, y: 1 };
        e.preventDefault();
        break;
      case 'ArrowLeft':
      case 'a':
      case 'A':
        if (direction.x !== 1) nextDirection = { x: -1, y: 0 };
        e.preventDefault();
        break;
      case 'ArrowRight':
      case 'd':
      case 'D':
        if (direction.x !== -1) nextDirection = { x: 1, y: 0 };
        e.preventDefault();
        break;
      case ' ':
        isPaused = !isPaused;
        if (isPaused) draw();
        e.preventDefault();
        break;
    }
  });

  // initial draw
  init();
  draw();
</script>

<style>
  .game-container {
    max-width: 480px;
  }

  .game-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .game-stats {
    display: flex;
    gap: 24px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .stat-label {
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-value {
    font-family: var(--mono);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  #game-canvas {
    display: block;
    width: 100%;
    max-width: 480px;
    aspect-ratio: 1;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .game-info {
    margin-top: 16px;
    text-align: center;
  }

  .game-info p {
    margin: 0;
    color: var(--text-tertiary);
    font-size: 0.85rem;
  }

  @media (max-width: 520px) {
    #game-canvas {
      width: 100%;
      height: auto;
    }
  }
</style>
